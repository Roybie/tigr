[
    Test.suite('Net — TCP connect / listen', [
        Test.case('a listener bound to port 0 reports its OS-assigned port', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            Net.close(listener);
            Test.assert(port > 0, 'port 0 should resolve to a real port')
        }),

        Test.case('a spawned actor echoes bytes back over a socket', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                msg := N.read(conn, 1024);
                N.write(conn, msg);
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            Net.write(client, Bytes.from_string('ping'));
            reply := Net.read_exact(client, 4);
            Net.close(client);
            join(server);
            Test.assert_eq(Bytes.to_string(reply), 'ping')
        }),
    ]),

    Test.suite('Net — framed reads', [
        Test.case('read_line / read_exact / read_all share the socket buffer', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                B := import 'Bytes';
                conn := N.accept(listener);
                N.write(conn, B.from_string('line one\nline two\nABCDEFrest'));
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            l1   := Net.read_line(client);
            l2   := Net.read_line(client);
            six  := Net.read_exact(client, 6);
            rest := Net.read_all(client);
            Net.close(client);
            join(server);
            Test.assert_eq(l1, 'line one');
            Test.assert_eq(l2, 'line two');
            Test.assert_eq(Bytes.to_string(six), 'ABCDEF');
            Test.assert_eq(Bytes.to_string(rest), 'rest')
        }),

        Test.case('read_line returns null at end-of-stream', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            line := Net.read_line(client);
            Net.close(client);
            join(server);
            Test.assert_eq(line, null)
        }),

        Test.case('read past end-of-stream yields empty Bytes', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            chunk := Net.read(client, 16);
            Net.close(client);
            join(server);
            Test.assert_eq(#chunk, 0)
        }),
    ]),

    Test.suite('Net — close & timeout', [
        Test.case('close unblocks a reader stuck mid-read', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                N.read_all(conn);            // blocks until the client closes
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            reader := spawn fn() {
                N := import 'Net';
                N.read(client, 16)
            };
            Time.sleep_ms(100);              // let the reader reach its read
            Net.close(client);               // unblocks it — read returns EOF
            got := join(reader);
            join(server);
            Test.assert_eq(#got, 0)
        }),

        Test.case('a read past set_timeout raises timeout', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                N.read_all(conn);            // hold the connection open
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            Net.set_timeout(client, 100);
            Test.assert_raises(fn() { Net.read(client, 16) }, 'timeout');
            Net.close(client);
            join(server)
        }),

        Test.case('close is idempotent and a closed socket raises closed', fn() {
            listener := Net.listen('127.0.0.1', 0);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                N.read_all(conn);
                N.close(conn);
                N.close(listener);
                null
            };
            client := Net.connect('127.0.0.1', port);
            Net.close(client);
            Net.close(client);               // idempotent — no raise
            Test.assert_raises(fn() { Net.read(client, 8) }, 'closed');
            join(server)
        }),
    ]),

    Test.suite('Net — UDP datagrams', [
        Test.case('send_to / recv_from round-trip a datagram', fn() {
            receiver := Net.bind('127.0.0.1', 0);
            port := Net.local_addr(receiver).port;
            sender := Net.bind('127.0.0.1', 0);
            Net.send_to(sender, Bytes.from_string('udp hello'), '127.0.0.1', port);
            got := Net.recv_from(receiver, 1024);
            Net.close(sender);
            Net.close(receiver);
            Test.assert_eq(Bytes.to_string(got.data), 'udp hello')
        }),
    ]),

    Test.suite('Net — argument errors', [
        Test.case('an operation on a non-socket raises type_mismatch', fn() {
            Test.assert_raises(fn() { Net.read(42, 8) }, 'type_mismatch')
        }),

        Test.case('a port outside 0..=65535 is rejected', fn() {
            Test.assert_raises(fn() { Net.connect('127.0.0.1', 99999) })
        }),
    ]),

    Test.suite('Net — TLS server', [
        Test.case('listen_tls binds and reports its OS-assigned port', fn() {
            listener := Net.listen_tls('127.0.0.1', 0, TEST_CERT, TEST_KEY);
            port := Net.local_addr(listener).port;
            Net.close(listener);
            Test.assert(port > 0, 'port 0 should resolve to a real port')
        }),

        // This case `spawn`s the server, so each actor holds a single
        // coroutine — every socket call runs blocking on the inline
        // executor, never the reactor. The `go`-based suite below is
        // what drives the reactor TLS-server path.
        Test.case('a TLS client and TLS server round-trip a line', fn() {
            listener := Net.listen_tls('127.0.0.1', 0, TEST_CERT, TEST_KEY);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                B := import 'Bytes';
                conn := N.accept(listener);      // yields a TLS socket
                line := N.read_line(conn);
                N.write(conn, B.from_string('echo: ' + line + '\n'));
                N.close(conn);
                N.close(listener);
                null
            };
            // The 3rd arg trusts TEST_CERT as a private CA, so the
            // self-signed server certificate verifies.
            client := Net.connect_tls('127.0.0.1', port, TEST_CERT);
            Net.write(client, Bytes.from_string('ping\n'));
            reply := Net.read_line(client);
            Net.close(client);
            join(server);
            Test.assert_eq(reply, 'echo: ping')
        }),

        Test.case('listen_tls raises tls on a malformed certificate', fn() {
            Test.assert_raises(
                fn() { Net.listen_tls('127.0.0.1', 0, 'not a pem', TEST_KEY) },
                'tls')
        }),

        Test.case('listen_tls raises tls on a cert/key mismatch', fn() {
            Test.assert_raises(
                fn() { Net.listen_tls('127.0.0.1', 0, TEST_CERT, MISMATCH_KEY) },
                'tls')
        }),

        Test.case('connect_tls without the CA arg rejects a self-signed server', fn() {
            listener := Net.listen_tls('127.0.0.1', 0, TEST_CERT, TEST_KEY);
            port := Net.local_addr(listener).port;
            server := spawn fn() {
                N := import 'Net';
                conn := N.accept(listener);
                // The client aborts the handshake (untrusted cert);
                // driving a read surfaces that — swallow it, shut down.
                try { N.read_line(conn) } catch (e) { null };
                N.close(conn);
                N.close(listener);
                null
            };
            Test.assert_raises(
                fn() { Net.connect_tls('127.0.0.1', port) }, 'tls');
            join(server)
        }),
    ]),

    // Driving a TLS server on the async-IO reactor. Each case keeps
    // both endpoints in this one actor as `go` coroutines, so the actor
    // is never idle when a TLS call dispatches — that routes every
    // `accept` / `read` / `write` to the reactor instead of the inline
    // executor. The accepted server socket starts un-handshaked: the
    // handshake completes lazily on the first reactor-driven I/O, so
    // these cases exercise the lazy handshake (`pump_handshake`) and
    // the `TlsListener` accept path that the `spawn`ed suite does not.
    Test.suite('Net — TLS on the reactor', [
        Test.case('a client-speaks-first TLS round-trip on the reactor', fn() {
            listener := Net.listen_tls('127.0.0.1', 0, TEST_CERT, TEST_KEY);
            port := Net.local_addr(listener).port;
            reply := null;
            // Server: the first op on the accepted socket is a read, so
            // the handshake is driven through `tls_read`.
            go fn() {
                conn := Net.accept(listener);
                line := Net.read_line(conn);
                Net.write(conn, Bytes.from_string('echo: ' + line + '\n'));
                Net.close(conn);
                Net.close(listener)
            };
            go fn() {
                client := Net.connect_tls('127.0.0.1', port, TEST_CERT);
                Net.write(client, Bytes.from_string('ping\n'));
                reply = Net.read_line(client);
                Net.close(client)
            };
            while (reply == null) { yield };
            Test.assert_eq(reply, 'echo: ping')
        }),

        Test.case('a server-speaks-first TLS exchange completes the handshake', fn() {
            listener := Net.listen_tls('127.0.0.1', 0, TEST_CERT, TEST_KEY);
            port := Net.local_addr(listener).port;
            greeting := null;
            // Server: the first op is a write — on an un-handshaked
            // server connection that needs `pump_handshake` inside
            // `tls_write`, or this would deadlock.
            go fn() {
                conn := Net.accept(listener);
                Net.write(conn, Bytes.from_string('server speaks first\n'));
                Net.close(conn);
                Net.close(listener)
            };
            go fn() {
                client := Net.connect_tls('127.0.0.1', port, TEST_CERT);
                greeting = Net.read_line(client);
                Net.close(client)
            };
            while (greeting == null) { yield };
            Test.assert_eq(greeting, 'server speaks first')
        }),

        Test.case('a parked TLS read does not freeze a sibling coroutine', fn() {
            listener := Net.listen_tls('127.0.0.1', 0, TEST_CERT, TEST_KEY);
            port := Net.local_addr(listener).port;
            got := null;
            counter := 0;
            go fn() {
                conn := Net.accept(listener);
                got = Net.read_line(conn);       // parks on the reactor
                Net.close(conn);
                Net.close(listener)
            };
            go fn() { while (got == null) { counter = counter + 1; yield } };
            go fn() {
                client := Net.connect_tls('127.0.0.1', port, TEST_CERT);
                Net.write(client, Bytes.from_string('delayed\n'));
                Net.close(client)
            };
            while (got == null) { yield };
            Test.assert_eq(got, 'delayed');
            Test.assert(counter > 0,
                'a sibling should run while the TLS read is parked')
        }),
    ]),
]

// tests/net_test.tg — v0.15 networking: the `Net` module.
//
// Every case runs in-process over the loopback interface, so the suite
// stays offline — no case touches the public network. The TLS-server
// suite is hermetic too: it `listen_tls`es with a throwaway self-signed
// certificate (the `TEST_CERT` / `TEST_KEY` constants below) and a
// matching `connect_tls(..., TEST_CERT)` trusts it as a private CA.
//
// The echo and close-unblocks cases pass a socket into a `spawn`ed
// actor, exercising `Transfer::Socket` across the actor boundary. An
// actor shares nothing, so it `import`s `Net` itself — only the socket
// handles are captured (sockets are sendable, like channels).
//
// Evaluates to an array of suites so `tigr test` aggregates each tally.

Net   := import 'Net';
Test  := import 'Test';
Bytes := import 'Bytes';
Time  := import 'Time';

// A throwaway self-signed certificate for `localhost` / `127.0.0.1`,
// generated once with `openssl req -x509` (valid ~100 years, so the
// suite never expires; `CA:FALSE`, so it is valid as a server leaf).
// Embedded as raw strings — `"…"` does not interpolate or escape, so
// the PEM's literal newlines pass through.
TEST_CERT := "-----BEGIN CERTIFICATE-----
MIIDJDCCAgygAwIBAgIUHGaC7x8IAUhI5G7GcTFbJgCIiNMwDQYJKoZIhvcNAQEL

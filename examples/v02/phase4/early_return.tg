// `return` exits the innermost function with the given value (or null).
// Demonstrates short-circuit logic via early return.

find_index := fn(arr, target) {
    i := 0;
    while i < #arr {
        if arr[i] == target { return i };
        i += 1
    };
    return -1     // not found
};

print('index of 7:', find_index([3, 5, 7, 11, 13], 7));    // 2
print('index of 99:', find_index([3, 5, 7, 11, 13], 99))   // -1

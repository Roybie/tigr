// FizzBuzz-ish: count to 15, but track only the kind of last term.
// (No print yet — that arrives in Phase 3 along with strings as data.)
i := 1;
last := 'start';
while i <= 15 {
    last = if i % 15 == 0 {
        'fizzbuzz'
    } else if i % 3 == 0 {
        'fizz'
    } else if i % 5 == 0 {
        'buzz'
    } else {
        'number'
    };
    i = i + 1
};
last

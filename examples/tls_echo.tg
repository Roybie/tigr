1MjbLLo2z5DEiMJGwo+q0ZM5bJmicDwK8KPTujqA85xvLZHcJ1LNL+TECXe/ay6J
M1Urz00ZnqiZaAmTqtdp2sg=
-----END PRIVATE KEY-----
";

listener := Net.listen_tls('127.0.0.1', 0, TLS_CERT, TLS_KEY);
port := Net.local_addr(listener).port;
print('TLS echo server listening on 127.0.0.1:' + str(port));

// The server: accept three connections, hand each to its own handler
// actor, then join the handlers and stop. The handler body below is
// the same as `tcp_echo.tg` — `accept` already returned a TLS socket.
server := spawn fn() {
    handlers := for[] (i, 1..=3) {
        conn := Net.accept(listener);
        spawn fn() {
            line := Net.read_line(conn);
            Net.write(conn, Bytes.from_string('echo: ' + line + '\n'));
            Net.close(conn);
            null
        }
    };
    for (h, handlers) { join(h) };
    Net.close(listener);
    null
};

// Three clients, each opening a TLS connection, sending one line and
// reading the echo back. The 3rd `connect_tls` argument trusts the
// server's self-signed certificate as a private CA.
replies := for[] (i, 1..=3) {
    client := Net.connect_tls('127.0.0.1', port, TLS_CERT);
    Net.write(client, Bytes.from_string('hello ' + str(i) + '\n'));
    reply := Net.read_line(client);
    Net.close(client);
    reply
};

print('clients received:', replies);
join(server);

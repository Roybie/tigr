// Object literal with both ident-key and quoted-key forms;
// member sugar, and reference semantics.
o := ${
    name: 'tigr',
    'with space': 42,
    nested: ${ inner: true },
};
o.color = 'red';
print('name =', o.name);
print('space =', o['with space']);
print('inner =', o.nested.inner);
print('color =', o.color);
#o

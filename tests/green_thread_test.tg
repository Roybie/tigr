// tests/green_thread_test.tg — green threads: `go` and `yield`.
//
// A green thread (coroutine) spawned with `go` runs inside the current
// actor, sharing its heap, scheduled cooperatively: it runs until it
// `yield`s or returns, then the scheduler hands control to the next
// ready coroutine round-robin. Unlike `spawn` (a separate OS-thread
// actor), a green thread shares mutable state with its enclosing
// scope — no copying, no channels needed.
//
// Each case fully drains the coroutines it spawns before returning, so
// the scheduler queue is empty between cases. The `while (!done)
// { yield }` idiom pumps the scheduler until a coroutine signals it
// has finished — extra `yield`s with nothing ready are harmless no-ops.
//
// Evaluates to an array of suites so `tigr test` aggregates each tally.

Test := import 'Test';

[
    Test.suite('go — basics', [
        Test.case('go evaluates to a green-thread handle', fn() {
            // the handle is opaque; `join` reads the coroutine's
            // return value once it finishes.
            h := go fn() { 42 };
            Test.assert_eq(join(h), 42)
        }),

        Test.case('a coroutine runs and reports completion', fn() {
            done := false;
            go fn() { done = true };
            while (!done) { yield };
            Test.assert(done)
        }),

        Test.case('a coroutine shares and mutates an outer variable', fn() {
            log := [];
            go fn() { log = log + ['from coroutine'] };
            while (#log == 0) { yield };
            Test.assert_eq(log, ['from coroutine'])
        }),

        Test.case('a coroutine can communicate through shared state', fn() {
            // besides its return value, a coroutine can simply mutate
            // a captured variable — no handle needed.
            seen := 0;
            go fn() { seen = 7; 999 };
            while (seen == 0) { yield };
            Test.assert_eq(seen, 7)
        }),
    ]),

    Test.suite('yield — scheduling', [
        Test.case('main and a coroutine interleave at yield points', fn() {
            log := [];
            go fn() {
                log = log + ['c1'];
                yield;
                log = log + ['c2'];
                yield;
                log = log + ['c3']
            };
            log = log + ['m1'];
            yield;
            log = log + ['m2'];
            yield;
            log = log + ['m3'];
            yield;
            Test.assert_eq(log, ['m1', 'c1', 'm2', 'c2', 'm3', 'c3'])
        }),

        Test.case('a lone yield with nothing ready resumes immediately', fn() {
            // no other coroutine exists, so yield is a no-op and the
            // expression evaluates to the resume value (null in v1).
            r := yield 123;
            Test.assert_eq(r, null)
        }),

        Test.case('round-robin order across three coroutines', fn() {
            order := [];
            mark := fn(tag) { order = order + [tag] };
            go fn() { mark('a'); yield; mark('a') };
            go fn() { mark('b'); yield; mark('b') };
            go fn() { mark('c'); yield; mark('c') };
            // pump until all six marks have landed
            while (#order < 6) { yield };
            Test.assert_eq(order, ['a', 'b', 'c', 'a', 'b', 'c'])
        }),
    ]),

    Test.suite('go — composition', [
        Test.case('a coroutine can spawn another coroutine', fn() {
            log := [];
            go fn() {
                log = log + ['outer'];
                go fn() { log = log + ['inner'] };
                yield;
                log = log + ['outer-done']
            };
            while (#log < 3) { yield };
            Test.assert_eq(log, ['outer', 'inner', 'outer-done'])
        }),

        Test.case('many coroutines all run to completion', fn() {
            hits := [];
            for (i, 1..=8) {
                go fn() { hits = hits + [i * i] }
            };
            while (#hits < 8) { yield };
            // round-robin spawn order is preserved
            Test.assert_eq(hits, [1, 4, 9, 16, 25, 36, 49, 64])
        }),

        Test.case('a counter shared across coroutines', fn() {
            count := 0;
            for (_, 1..=5) {
                go fn() { count = count + 1 }
            };
            while (count < 5) { yield };
            Test.assert_eq(count, 5)
        }),
    ]),

    Test.suite('go — errors', [
        Test.case('try/catch inside a coroutine spans a yield', fn() {
            result := null;
            go fn() {
                result = try {
                    yield;
                    raise 'boom'
                } catch (e) {
                    'caught: ' + e
                }
            };
            while (result == null) { yield };
            Test.assert_eq(result, 'caught: boom')
        }),
    ]),

    Test.suite('join — waiting on a coroutine', [
        Test.case('join waits for a still-running coroutine', fn() {
            // the coroutine has not started; join pumps it through
            // both yields to completion and yields its return value.
            h := go fn() { yield; yield; 'done' };
            Test.assert_eq(join(h), 'done')
        }),

        Test.case('join on an already-finished coroutine', fn() {
            h := go fn() { 7 };
            yield;   // let the coroutine run and return
            Test.assert_eq(join(h), 7)
        }),

        Test.case('join yields a value the coroutine computed', fn() {
            h := go fn() {
                x := 0;
                for (i, 1..=5) { x = x + i };
                x
            };
            Test.assert_eq(join(h), 15)
        }),

        Test.case('a handle can be joined more than once', fn() {
            h := go fn() { 99 };
            a := join(h);
            b := join(h);
            Test.assert_eq([a, b], [99, 99])
        }),

        Test.case('a coroutine can join another coroutine', fn() {
            result := null;
            go fn() {
                inner := go fn() { 21 * 2 };
                result = join(inner)
            };
            while (result == null) { yield };
            Test.assert_eq(result, 42)
        }),

        Test.case('joining many coroutines collects each result', fn() {
            handles := for[] (i, 1..=6) { go fn() { i * 10 } };
            results := for[] (h, handles) { join(h) };
            Test.assert_eq(results, [10, 20, 30, 40, 50, 60])
        }),

        Test.case('join surfaces a raise from the coroutine body', fn() {
            // an uncaught raise in a `go` body aborts the actor, so a
            // body that might fail should catch internally and return
            // a tagged result for the joiner to inspect.
            h := go fn() {
                try { raise 'oops' } catch (e) { ${ error: e } }
            };
            Test.assert_eq(join(h), ${ error: 'oops' })
        }),
    ]),
]

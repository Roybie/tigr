// tests/fold_test.tg — v0.12 item 15: constant folding.
//
// Folding is a compile-time rewrite and must be invisible at runtime.
// These tests check two things: that folded literal expressions
// produce the correct value, and that operations which would *raise*
// (overflow, divide-by-zero, out-of-range shift) are NOT folded away —
// the VM must still raise the same catchable error.

Test := import 'Test';

values := Test.suite('Constant folding — values are preserved', [
    Test.case('nested integer arithmetic folds correctly', fn() {
        Test.assert_eq(2 + 3 * 4, 14);
        Test.assert_eq(100 * 100, 10000);
        Test.assert_eq(1000 - 7 * 7, 951)
    }),

    Test.case('parenthesised sub-expressions fold', fn() {
        Test.assert_eq((3 + 4) * 2, 14);
        Test.assert_eq(64 / 8, 8);
        Test.assert_eq(((1 + 1) + 1) * 10, 30)
    }),

    Test.case('string concatenation folds', fn() {
        Test.assert_eq('a' + 'b' + 'c', 'abc')
    }),

    Test.case('unary and bitwise operators fold', fn() {
        Test.assert_eq(-5, 0 - 5);
        Test.assert_eq(0xF0 & 0x0F, 0);
        Test.assert_eq(1 << 10, 1024);
        Test.assert_eq(~0, -1)
    }),

    // Divergence guard: a folded literal expression must equal the
    // same computation performed through variables (which the folder
    // never touches).
    Test.case('folded result matches the unfolded computation', fn() {
        x := 2;
        y := 3;
        Test.assert_eq(2 + 3, x + y);
        Test.assert_eq(7 * 6, (fn(a, b) { a * b })(7, 6))
    }),
]);

raises := Test.suite('Constant folding — raising operations are not folded', [
    Test.case('literal integer overflow still raises', fn() {
        Test.assert_raises(fn() { 9223372036854775807 + 1 }, 'overflow')
    }),

    Test.case('literal division by zero still raises', fn() {
        Test.assert_raises(fn() { 1 / 0 }, 'div_by_zero');
        Test.assert_raises(fn() { 5 % 0 }, 'div_by_zero')
    }),

    Test.case('out-of-range literal shift still raises', fn() {
        Test.assert_raises(fn() { 1 << 64 })
    }),
]);

[values, raises]
